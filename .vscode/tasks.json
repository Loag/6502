{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-configure-debug",
      "type": "shell",
      "command": "cmake --preset dev-debug",
      "problemMatcher": []
    },
    {
      "label": "cmake-build-debug",
      "type": "shell",
      "command": "cmake --build --preset build-debug",
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "cmake-build-sanitize",
      "type": "shell",
      "command": "cmake --build --preset build-sanitize",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "cmake-test-debug",
      "type": "shell",
      "command": "ctest --test-dir build/dev-debug --output-on-failure",
      "problemMatcher": []
    },
    {
      "label": "ctest-sanitize",
      "type": "shell",
      "command": "ctest --test-dir build/dev-sanitize --output-on-failure",
      "problemMatcher": []
    },
    {
      "label": "format",
      "type": "shell",
      "command": "find app include src tests -name '*.cpp' -o -name '*.hpp' | xargs clang-format -i",
      "problemMatcher": []
    }
  ]
}